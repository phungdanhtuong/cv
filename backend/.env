# Environment
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doan_web1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doan_web1
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# Claude API
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-opus-4-7

# Facebook/Meta
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_BUSINESS_ACCOUNT_ID=your_business_account_id
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback

# Meta Ads MCP
META_ADS_MCP_ENDPOINT=https://mcp.pipeboard.co/meta-ads-mcp

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/auth/linkedin/callback

# TikTok
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback

# Instagram
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Logging
LOG_LEVEL=debug
